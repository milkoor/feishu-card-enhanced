{
  "id": "feishu-card-enhanced",
  "version": "1.3.0",
  "main": "./index.js",
  "description": "飞书任务卡片插件 - 集中展示分步任务和对话流，支持创建、更新、伪刷新置底、错误重试",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "tools": [
    {
      "name": "task_card_create",
      "description": "创建一个新的任务卡片，用于展示分步任务和对话流",
      "parameters": {
        "receive_id_type": "open_id | user_id | email | chat_id",
        "receive_id": "接收者 ID",
        "task": {
          "task_id": "可选，不提供则自动生成",
          "title": "卡片标题",
          "titleTemplate": "blue | green | red | yellow | orange | purple | grey",
          "lang": "zh | en",
          "status": "todo | doing | done | error",
          "subtasks": [{ "id": "子任务ID", "label": "名称", "status": "todo|doing|done|error", "detail": "详情" }],
          "messages": [{ "text": "消息内容", "level": "info|warn|error", "time": "时间" }],
          "actions": [{ "text": "按钮文本", "action": "动作名", "type": "primary|default", "payload": {} }]
        }
      }
    },
    {
      "name": "task_card_update",
      "description": "更新已有任务卡片的状态、子任务、消息流等",
      "parameters": {
        "task_id": "任务 ID（必需）",
        "title": "新标题",
        "titleTemplate": "标题颜色",
        "status": "todo | doing | done | error",
        "subtasks": "子任务列表",
        "messages": "消息列表",
        "actions": "操作按钮",
        "lastError": "错误信息（传入后卡片变红）",
        "lang": "zh | en"
      }
    },
    {
      "name": "task_card_append",
      "description": "追加子任务或消息到现有卡片",
      "parameters": {
        "task_id": "任务 ID",
        "subtask": { "id": "ID", "label": "名称", "status": "状态", "detail": "详情" },
        "message": { "text": "内容", "level": "info|warn|error" },
        "set_status": "同时设置状态"
      }
    },
    {
      "name": "task_card_refresh_bottom",
      "description": "删除旧卡片并重新发送，保持在对话最下方",
      "parameters": {
        "task_id": "任务 ID"
      }
    },
    {
      "name": "task_card_get",
      "description": "获取任务当前状态",
      "parameters": {
        "task_id": "任务 ID"
      }
    },
    {
      "name": "task_card_delete",
      "description": "删除任务卡片",
      "parameters": {
        "task_id": "任务 ID"
      }
    },
    {
      "name": "task_card_health",
      "description": "检查飞书连通性和插件状态",
      "parameters": {}
    }
  ]
}